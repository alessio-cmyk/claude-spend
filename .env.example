# Team server port (default: 3457)
PORT=3457

# Data storage directory (default: ./data/team)
CLAUDE_SPEND_DATA=./data/team

# HMAC salt for deterministic API key generation (required for generate-keys.js)
# Pick any random string and keep it secret — changing it invalidates all keys
HMAC_SALT=change-me-to-something-random

# S3 persistence (required for App Runner / ephemeral environments)
# Leave S3_BUCKET empty to disable S3 and use local filesystem only
S3_BUCKET=
S3_PREFIX=team/
AWS_REGION=us-east-1

# SSM Parameter Store prefix (used by boot.js on App Runner)
# All params under this prefix are loaded as env vars at startup
# Set in App Runner env vars — not needed for local development
# SSM_PREFIX=/claude-spend/
